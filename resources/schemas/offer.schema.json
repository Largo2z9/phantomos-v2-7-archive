{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Product Offers v2.0 DRAFT",
  "description": "Commercial offers for a product — v2.0 design draft. Breaking changes from v1.8: flat offers[] wrapped in offer_groups[] with attribute inheritance (2-level, group → offer). Lives in brands/{slug}/products/{slug}/offers.json once validated.",
  "type": "object",
  "required": ["meta", "offer_groups"],
  "properties": {
    "$comment": { "type": "string" },
    "_schema": { "type": "string" },
    "_version": { "type": "string", "const": "2.0" },
    "_field_types": { "type": "object", "additionalProperties": { "type": "string" } },

    "meta": {
      "type": "object",
      "required": ["product_slug", "scope"],
      "properties": {
        "product_slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "scope": {
          "type": "string",
          "const": "pre_cart",
          "description": "v2.0: offers.json describes ONLY pre-add-to-cart merchandising (PDP offers, bundle builders, quiz results, subscription choices). Post-cart funnels (post-purchase upsell, thank-you cross-sell, order-confirmation bumps) live in funnel.json (future). Binary rule: if it's shown before the customer clicks add-to-cart, it's here. Otherwise, it's not."
        },
        "updated": { "type": "string" }
      }
    },

    "offer_groups": {
      "type": "array",
      "description": "v2.0: offers are ALWAYS wrapped in a group, even a standalone offer (group of 1). Enables shared attributes with inheritance. Group-level fields cascade to all offers in the group unless overridden. Merge rule: objects deep-merge, arrays replace.",
      "items": {
        "type": "object",
        "required": ["group_id", "offers"],
        "properties": {

          "group_id": { "type": "string", "pattern": "^GRP-[0-9]+$" },
          "name": { "type": "string" },
          "description": { "type": "string" },

          "active": { "type": "boolean", "default": true },
          "active_from": { "type": ["string", "null"] },
          "active_until": { "type": ["string", "null"] },

          "shared": {
            "type": "object",
            "description": "Attributes inherited by all offers in this group. MERGE RULES: (1) nested objects merge deep — offer.pricing.price overrides group only on 'price' and keeps group 'currency'; (2) arrays replace entirely — offer.payment_options.methods replaces group.shared.payment_options.methods with no union; (3) scalars and booleans override explicitly — offer.subscription.trial.enabled:false overrides a shared true, treating the override as a conscious act. VALIDATION TIMING: the validator MUST resolve merge (shared→offer) BEFORE running JSON Schema validation on each offer. A raw un-merged offer may legitimately omit required fields that live in group.shared — only the resolved offer is checked against the base offer schema. Implementation: see resources/scripts/validate-all.py resolve_offer() step (added post v2.0 bump).",
            "properties": {

              "target_audience_id": { "type": ["string", "null"] },

              "pricing": {
                "type": "object",
                "description": "Shared pricing frame (currency, model defaults). Individual offers override price/savings.",
                "properties": {
                  "model": { "type": "string", "enum": ["one_shot", "subscription", "tiered"] },
                  "currency": { "type": "string", "default": "EUR" }
                }
              },

              "subscription": {
                "type": ["object", "null"],
                "description": "Shared subscription frame. Typical use: group all frequency variants (weekly / monthly / quarterly) with same skip/pause/cancellation/trial rules; only frequency differs per offer."
              },

              "shipping": {
                "type": ["object", "null"],
                "description": "Shared shipping config for all offers in group.",
                "properties": {
                  "free": { "type": "boolean", "default": false },
                  "threshold": { "type": ["number", "null"] },
                  "zones": { "type": "array", "items": { "type": "string" } },
                  "carrier": { "type": ["string", "null"] },
                  "estimated_days_min": { "type": ["number", "null"] },
                  "estimated_days_max": { "type": ["number", "null"] }
                }
              },

              "warranty": {
                "type": ["object", "null"],
                "description": "Shared warranty (typical hardware brands: Tushy, Frank Body).",
                "properties": {
                  "duration_months": { "type": ["number", "null"] },
                  "covers": { "type": "array", "items": { "type": "string" } },
                  "extended_available": { "type": ["boolean", "null"] }
                }
              },

              "returns": {
                "type": ["object", "null"],
                "description": "Shared return policy (30-day, 100-night trial, etc.).",
                "properties": {
                  "window_days": { "type": ["number", "null"] },
                  "restocking_fee_pct": { "type": ["number", "null"] },
                  "return_shipping": { "type": "string", "enum": ["free", "prepaid_label", "customer_paid", "not_accepted"] },
                  "conditions": { "type": ["string", "null"] }
                }
              },

              "payment_options": {
                "type": ["object", "null"],
                "description": "Shared payment methods + BNPL.",
                "properties": {
                  "methods": { "type": "array", "items": { "type": "string" } },
                  "installments": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "nb_installments": { "type": "number" },
                        "provider": { "type": "string" },
                        "min_order_value": { "type": ["number", "null"] }
                      }
                    }
                  }
                }
              },

              "incentives": {
                "type": ["object", "null"],
                "description": "Shared incentives that apply to all offers in group (e.g. a gift given regardless of which duration the customer picks, or a referral program that covers the whole group)."
              },

              "urgency": {
                "type": ["object", "null"],
                "description": "Shared urgency (flash sale window applying to whole group)."
              },

              "gifting": {
                "type": ["object", "null"]
              },

              "tags": {
                "type": "array",
                "description": "Shared tags inherited by all offers in group.",
                "items": { "type": "string" }
              }
            }
          },

          "offers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["offer_id", "name", "type", "pricing", "active", "product_refs"],
              "properties": {

                "offer_id": { "type": "string", "pattern": "^OFR-[0-9]+$" },
                "name": { "type": "string" },

                "type": {
                  "type": "string",
                  "enum": [
                    "single",
                    "bundle",
                    "prepay",
                    "subscription",
                    "membership",
                    "gifting",
                    "seasonal",
                    "launch",
                    "digital",
                    "service"
                  ],
                  "description": "v2.0: 10 structural types. Note: hardware bundles (Bruvi, Gozney) = type 'bundle' + tags[hardware] + requires_offer_id on the refill offer. Personalized offers (Care/of, Prose) = type 'subscription' (or 'bundle') + personalization{} pointer. Type describes SHAPE of data, not commercial strategy — use tags[] for the latter."
                },

                "requires_offer_id": {
                  "type": ["string", "null"],
                  "description": "v2.0: prerequisite offer that must be owned before this one can be purchased. Typical case: consumables/refills that require the hardware bundle first. Ex: 'OFR-01' (coffee pods offer requires OFR-05 Bruvi machine). Null if standalone."
                },

                "product_refs": {
                  "type": "array",
                  "description": "v2.0: REQUIRED on every offer. Each offer declares its own product_refs explicitly — no inheritance of product_refs from group.shared (avoids ghost-offer bugs). Shared attributes live in offer_groups.shared, but product identity is always explicit per offer.",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["slug"],
                    "properties": {
                      "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                      "quantity": { "type": "number", "minimum": 1, "default": 1 },
                      "variant": { "type": ["string", "null"] }
                    }
                  }
                },

                "pricing": {
                  "type": "object",
                  "description": "Offer-level pricing. Merges with group.shared.pricing (deep merge).",
                  "required": ["price"],
                  "properties": {
                    "model": { "type": "string", "enum": ["one_shot", "subscription", "tiered"] },
                    "price": { "type": ["number", "null"] },
                    "price_original": { "type": ["number", "null"] },
                    "price_per_unit": {
                      "oneOf": [
                        { "type": "null" },
                        {
                          "type": "object",
                          "required": ["value", "unit"],
                          "properties": {
                            "value": { "type": "number" },
                            "currency": { "type": "string", "default": "EUR" },
                            "unit": {
                              "type": "string",
                              "enum": ["serving", "dose", "day", "week", "month", "100g", "100ml", "kg", "liter", "gelule", "capsule", "tablet", "scoop", "sachet", "wash", "use", "application", "ml", "g", "unit", "meal", "piece"]
                            }
                          }
                        }
                      ]
                    },
                    "currency": { "type": "string", "default": "EUR" },
                    "savings_amount": { "type": ["number", "null"] },
                    "savings_percent": { "type": ["number", "null"] },
                    "price_comparison_note": { "type": ["string", "null"] }
                  }
                },

                "contents": {
                  "type": "object",
                  "description": "Same structure as v1.8 contents (is_prepay, prepay_type, quantity, unit_name, duration, duration_unit, duration_type, duration_servings, cure_metadata, included_items, delivery_type, fulfillment_notes, fulfillment_delay, variant_selection). See v1.8 schema for full sub-properties."
                },

                "subscription": {
                  "type": ["object", "null"],
                  "description": "Offer-level subscription config. Merges with group.shared.subscription. Typical pattern: group declares shipping/skip/pause/cancellation/trial once, offers declare per-frequency price + intro_phases.",
                  "properties": {
                    "frequency": { "type": ["string", "null"], "enum": ["weekly", "monthly", "quarterly", "custom", null] },
                    "frequency_options": { "type": "array", "items": { "type": "number" } },
                    "skip": { "type": "boolean", "default": false },
                    "pause": { "type": "boolean", "default": false },
                    "reschedule": { "type": "boolean", "default": false },
                    "required": { "type": ["boolean", "null"] },
                    "discount_type": { "type": ["string", "null"], "enum": ["percentage", "fixed_amount", null] },
                    "discount_value": { "type": ["number", "null"] },

                    "intro_phases": {
                      "type": "array",
                      "description": "v2.0 C3: cascading intro pricing replaces scalar intro_discount. Ordered phases, each applies from cycle N until the next phase starts. Ex: [{from_cycle:1, to_cycle:1, price:5}, {from_cycle:2, to_cycle:2, price:15}, {from_cycle:3, to_cycle:null, price:25}]. Null to_cycle = phase runs until churn. If empty, offer uses recurring_discount only.",
                      "items": {
                        "type": "object",
                        "required": ["from_cycle"],
                        "properties": {
                          "from_cycle": { "type": "number", "minimum": 1 },
                          "to_cycle": { "type": ["number", "null"] },
                          "price": { "type": ["number", "null"] },
                          "discount_type": { "type": ["string", "null"], "enum": ["percentage", "fixed_amount", null] },
                          "discount_value": { "type": ["number", "null"] },
                          "label": { "type": ["string", "null"], "description": "Human-readable phase name ('Welcome month', 'Ramp', 'Steady state')." }
                        }
                      }
                    },

                    "shipping": { "type": ["object", "null"] },
                    "cancellation": { "type": ["string", "null"] },
                    "commitment": {
                      "type": ["object", "null"],
                      "description": "v2.0 C6: structured commitment contract. Distinct from commitment_duration scalar (v1.8). Captures non_refundable, early_termination_fee, minimum_cycles.",
                      "properties": {
                        "minimum_cycles": { "type": ["number", "null"] },
                        "duration_label": { "type": ["string", "null"] },
                        "non_refundable": { "type": "boolean", "default": false },
                        "early_termination_fee": {
                          "type": ["object", "null"],
                          "properties": {
                            "type": { "type": "string", "enum": ["fixed_amount", "percentage", "remaining_balance"] },
                            "value": { "type": ["number", "null"] }
                          }
                        }
                      }
                    },
                    "churn_metrics": { "type": ["object", "null"] },
                    "trial": {
                      "type": "object",
                      "properties": {
                        "enabled": { "type": "boolean" },
                        "duration": { "type": ["number", "null"] },
                        "duration_unit": { "type": ["string", "null"], "enum": ["days", "weeks", "months", null] },
                        "requires_payment_method": { "type": "boolean" },
                        "converts_to_offer_id": { "type": ["string", "null"] }
                      }
                    }
                  }
                },

                "membership": {
                  "type": ["object", "null"],
                  "description": "v2.0 C2 (type='membership' only): access-based offer with perks + catalog discount. Distinct from subscription (which ships one specific product on cadence). Typical: Amazon Prime, Thrive Market, Costco, Bruvi loyalty club. Null if type != 'membership'.",
                  "properties": {
                    "billing_period": { "type": "string", "enum": ["monthly", "quarterly", "yearly", "lifetime"] },
                    "billing_price": { "type": "number" },
                    "perks": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Human-readable perks list ('free shipping', 'early access to drops', '10% off everything')."
                    },
                    "catalog_discount": {
                      "type": ["object", "null"],
                      "description": "Automatic discount applied to all (or filtered) offers in the brand catalog while membership is active.",
                      "properties": {
                        "type": { "type": "string", "enum": ["percentage", "fixed_amount"] },
                        "value": { "type": "number" },
                        "applies_to": {
                          "type": "string",
                          "enum": ["all_offers", "subscription_only", "one_shot_only", "tagged_offers"]
                        },
                        "tag_filter": { "type": ["string", "null"] }
                      }
                    },
                    "includes_products": {
                      "type": "array",
                      "description": "Products bundled with membership regardless of catalog purchase (Costco sample, welcome kit).",
                      "items": {
                        "type": "object",
                        "properties": {
                          "slug": { "type": "string" },
                          "quantity": { "type": "number" }
                        }
                      }
                    },
                    "physical_shipment": {
                      "type": "boolean",
                      "description": "true = membership also ships a physical item (welcome kit, member card). false = pure access."
                    },
                    "trial": { "type": ["object", "null"] }
                  }
                },

                "incentives": {
                  "type": "object",
                  "description": "Offer-level incentives. Merges with group.shared.incentives.",
                  "properties": {
                    "gifts": { "type": "array", "items": { "type": "object" } },
                    "discount": { "type": "object" },
                    "bulk_tiers": { "type": "array" },
                    "duration_tiers": { "type": "array" },
                    "loyalty": { "type": ["object", "null"] },
                    "variant_pricing_delta": { "type": "array" },
                    "referral": {
                      "type": ["object", "null"],
                      "properties": {
                        "enabled": { "type": "boolean" },
                        "referrer_reward": {
                          "type": "object",
                          "properties": {
                            "type": { "type": "string", "enum": ["credit", "percent_off", "fixed_off", "free_product"] },
                            "value": { "type": ["number", "null"] },
                            "product_refs": {
                              "type": "array",
                              "description": "v2.0 C8: when type='free_product', structured product reference instead of freetext. Enables validators and downstream instances to resolve the actual product.",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "slug": { "type": "string" },
                                  "quantity": { "type": "number", "default": 1 }
                                }
                              }
                            },
                            "description": { "type": ["string", "null"] }
                          },
                          "required": ["type"]
                        },
                        "referee_reward": {
                          "type": "object",
                          "properties": {
                            "type": { "type": "string", "enum": ["credit", "percent_off", "fixed_off", "free_product"] },
                            "value": { "type": ["number", "null"] },
                            "product_refs": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "slug": { "type": "string" },
                                  "quantity": { "type": "number", "default": 1 }
                                }
                              }
                            },
                            "description": { "type": ["string", "null"] }
                          },
                          "required": ["type"]
                        }
                      },
                      "required": ["enabled", "referrer_reward", "referee_reward"]
                    }
                  }
                },

                "urgency": {
                  "type": "object",
                  "properties": {
                    "limited_quantity": { "type": "boolean" },
                    "quantity_remaining": { "type": ["number", "null"] },
                    "limited_time": { "type": "boolean" },
                    "countdown": { "type": "boolean" },
                    "units_sold": { "type": ["number", "null"] },
                    "early_access": {
                      "type": ["object", "null"],
                      "description": "v2.0 C4 extension: cohort_tiers[] array replaces scalar cohort, lead_minutes supports sub-day drops.",
                      "properties": {
                        "enabled": { "type": "boolean" },
                        "cohort_tiers": {
                          "type": "array",
                          "description": "Ordered tiers, each with its own lead time. Ex: [{cohort:'vip', lead_minutes:1440}, {cohort:'subscribers', lead_minutes:720}, {cohort:'email_list', lead_minutes:60}]. Tier 0 = earliest access.",
                          "items": {
                            "type": "object",
                            "required": ["cohort", "lead_minutes"],
                            "properties": {
                              "cohort": { "type": "string", "enum": ["vip", "subscribers", "email_list", "sms_list", "app_users", "influencers", "paid_members"] },
                              "lead_minutes": { "type": "number", "minimum": 0 },
                              "channels": { "type": "array", "items": { "type": "string", "enum": ["sms", "email", "push", "app"] } }
                            }
                          }
                        }
                      }
                    }
                  }
                },

                "gifting": { "type": "object" },

                "payment_options": { "type": "object" },

                "personalization": {
                  "type": ["object", "null"],
                  "description": "v2.0 C5: pointer to external personalization logic (quiz, AI selector, profile-based filtering). offers.json only records WHICH mechanism applies — the rules engine lives in profile.json or a future config.json. Null if not personalized.",
                  "properties": {
                    "source": { "type": "string", "enum": ["quiz", "ai_selector", "profile_match", "consultation"] },
                    "source_id": { "type": ["string", "null"], "description": "ID of the quiz/selector/consultation flow." },
                    "dynamic_pricing": { "type": "boolean", "default": false, "description": "true = final price depends on personalization output (Care/of supplement stack)." },
                    "dynamic_contents": { "type": "boolean", "default": false, "description": "true = final product_refs depend on personalization output." }
                  },
                  "required": ["source"]
                },

                "placement": { "type": ["string", "null"], "enum": ["product_page", "email", "retargeting", null] },
                "landing_page": { "type": ["string", "null"] },
                "active": { "type": "boolean" },
                "active_from": { "type": ["string", "null"] },
                "active_until": { "type": ["string", "null"] },
                "order_index": { "type": "number" },
                "tags": { "type": "array", "items": { "type": "string" } },
                "_notes": { "type": "object" }
              }
            }
          }
        }
      }
    }
  }
}
