{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Audience Profile",
  "description": "Audience profile — deep psychographic and behavioral context, factual description of who they are. Lives in brands/{slug}/audiences/{audience}/profile.json. v1.2+: persona_archetype + buyer_user_split (migrated from spec.gift_economy). Canon V3 §8.2.",
  "_schema_version": "profile/1.3",
  "type": "object",
  "required": ["meta"],
  "properties": {
    "$comment": { "type": "string" },
    "_schema": { "type": "string" },
    "_version": { "type": "string" },
    "_field_types": { "type": "object", "additionalProperties": { "type": "string" } },

    "meta": {
      "type": "object",
      "description": "Identity card of the audience: name, slug, scope, parent/overlap relations, validation lifecycle.",
      "required": ["name", "slug"],
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string", "pattern": "^[a-z0-9-]*$" },
        "product_id": { "type": ["string", "null"], "deprecated": true, "description": "DEPRECATED v2.24.0: use applies_to_products[] instead. Kept for backward compatibility; readers should fall back to it if applies_to_products is empty." },
        "applies_to_products": { "type": "array", "items": { "type": "string" }, "description": "Slugs of products this audience applies to. Empty array = brand-wide audience (no specific product binding). Single element = mono-product audience. Multiple = cross-product audience. Drives /phantom navigation: /phantom {brand} products {p} surfaces audiences whose applies_to_products contains {p}." },
        "scope": { "type": "string", "enum": ["broad", "segment", "micro"] },
        "parent_slug": { "type": ["string", "null"] },
        "overlap_with": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "audience_type": { "type": "string", "enum": ["primary", "secondary", "discovered", "assumed"] },
        "validation_status": { "$ref": "_shared/validation-status.json" },
        "status": { "type": "string", "enum": ["draft", "partial", "complete"] },
        "created": { "type": "string" },
        "updated": { "type": "string" },
        "_notes": { "type": "object" }
      }
    },

    "purchase_driver": {
      "type": ["string", "null"],
      "description": "Resolved purchase driver from cascade brand → audience_tree → profile. _field_types = derived. Skills lookup d'abord profile.purchase_driver, fallback brand.purchase_driver si null. Audit Phase B v2.29.0 cascade documentation. Ne pas éditer manuellement (derived).",
      "default": null
    },

    "persona_archetype": {
      "type": "object",
      "description": "Archetype de definition de l'audience. Audit Phase B v2.29.0 : audiences reelles combinent souvent 2-3 archetypes simultanement (ex 'femmes 30-45 [demographic] en chute post-grossesse [condition_based] soucieuses de naturalite [psychographic]'). Forcer un seul = perte d'info. Transformation en {primary obligatoire, secondary[] optionnel}. Affecte la mecanique narrative recommandee (problem_solution > demographic, testimonial > condition_based, day_in_life > psychographic). Reference canon V3 §8.2.",
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "enum": ["demographic", "condition_based", "psychographic"],
          "description": "Archetype dominant. Le seul obligatoire."
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["demographic", "condition_based", "psychographic"]
          },
          "description": "Archetypes additionnels presents (audience hybride).",
          "uniqueItems": true,
          "maxItems": 2
        }
      }
    },

    "buyer_user_split": {
      "type": "object",
      "description": "Cas où l'acheteur n'est pas l'utilisateur du produit (cadeaux, B2B, pet, kids). Migration depuis spec.schema#gift_economy (S55 audit) car c'est une propriété d'audience, pas de produit.",
      "properties": {
        "is_split": { "type": "boolean" },
        "buyer_role": { "type": ["string", "null"], "description": "Qui achète (ex 'parent', 'mari', 'manager', 'owner')." },
        "user_role": { "type": ["string", "null"], "description": "Qui consomme/utilise (ex 'enfant 9-14', 'femme', 'employé', 'pet')." },
        "buyer_emotions": { "type": "array", "items": { "type": "string" }, "description": "Émotions du buyer (générosité, crainte de mal choisir, fierté de bien faire). Pour copy buyer-side." },
        "user_experience": { "type": "array", "items": { "type": "string" }, "description": "Expérience du user (surprise, utilité, plaisir). Pour copy user-side ou packaging." }
      }
    },

    "identity": {
      "type": "object",
      "description": "Demographic and lifestyle baseline of the audience: who they are factually (age, gender, profession, income, lifestyle, information sources).",
      "properties": {
        "description": { "type": "string" },
        "archetype": { "type": "string", "deprecated": true, "description": "DEPRECATED v2.29.0. Use `persona_archetype` enum (demographic/condition_based/psychographic). Will be removed in v2.31+. Free string legacy." },
        "age_range": {
          "type": "object",
          "properties": {
            "min": { "type": ["integer", "null"] },
            "max": { "type": ["integer", "null"] }
          }
        },
        "gender": { "type": ["string", "null"], "enum": ["male", "female", "all", ""] },
        "profession_category": { "type": "string" },
        "income_level": { "type": ["string", "null"], "enum": ["low", "medium", "high", "luxury", ""] },
        "lifestyle": { "type": "array", "items": { "type": "string" } },
        "information_sources": { "type": "array", "items": { "type": "string" } },
        "_notes": { "type": "object" }
      }
    },

    "role": {
      "type": "object",
      "description": "Audience role in the purchase decision (end user, buyer, influencer, gatekeeper). Distinguishes who uses from who pays from who recommends.",
      "properties": {
        "type": { "type": ["string", "null"], "enum": ["end_user", "buyer", "influencer", "gatekeeper", ""] },
        "proxy_link_id": { "type": ["string", "null"] },
        "_notes": { "type": "object" }
      }
    },

    "psychology": {
      "type": "object",
      "description": "Inner drivers of the audience: core desire, values, goals, limiting and facilitating beliefs, dominant emotions, social codes, life moments, and the Job To Be Done they hire the product for.",
      "properties": {
        "core_desire": { "type": "string" },
        "values": { "type": "array", "items": { "type": "string" } },
        "goals": { "type": "array", "items": { "type": "string" } },
        "beliefs_limiting": { "type": "array", "items": { "type": "string" } },
        "beliefs_facilitating": { "type": "array", "items": { "type": "string" } },
        "emotions": { "type": "array", "items": { "type": "string" } },
        "social_codes": { "type": "array", "items": { "type": "string" } },
        "life_moments": { "type": "array", "items": { "type": "string" } },
        "jtbd": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "context": { "type": "string" },
            "emotional_driver": { "type": ["string", "null"], "enum": ["status", "relief", "belonging", "control", "identity", ""] },
            "_notes": { "type": "object" }
          }
        },
        "_notes": { "type": "object" }
      }
    },

    "decision_process": {
      "type": "object",
      "description": "How the audience moves from unawareness to purchase: what triggers awareness, where they research, what they evaluate, who they trust, what tips them into buying, how risk-tolerant they are.",
      "properties": {
        "awareness_trigger": { "type": "string" },
        "research_behavior": {
          "type": "object",
          "properties": {
            "primary_sources": { "type": "array", "items": { "type": "string" } },
            "secondary_sources": { "type": "array", "items": { "type": "string" } },
            "decision_makers": { "type": ["string", "null"], "enum": ["self", "family", "peers", "influencer", "professional", ""] }
          }
        },
        "evaluation_criteria": { "type": "array", "items": { "type": "string" } },
        "trust_anchors": { "type": "array", "items": { "type": "string" } },
        "purchase_catalyst": { "type": "string" },
        "risk_tolerance": { "type": ["string", "null"], "enum": ["impulsive", "cautious", "needs_consensus", "waits_for_proof", ""] },
        "_notes": { "type": "object" }
      }
    },

    "behavior": {
      "type": "object",
      "description": "Observable purchase behavior: frequency, timeline from intent to checkout, dominant device, cart pattern, seasonal spikes, channel preferences. The factual side of how they buy.",
      "properties": {
        "purchase_frequency": { "type": ["string", "null"], "enum": ["one_time", "occasional", "regular", "subscription", ""] },
        "conversion_timeline": { "type": ["string", "null"], "enum": ["impulse", "short", "considered", "long", ""] },
        "dominant_device": { "type": ["string", "null"], "enum": ["mobile", "desktop", "mixed", ""] },
        "cart_behavior": { "type": ["string", "null"], "enum": ["direct", "comparison_shops", "abandons_and_returns", "waits_for_discount", ""] },
        "seasonal_spikes": { "type": "array", "items": { "type": "string" } },
        "channel_preferences": { "type": "array", "items": { "type": "string" } },
        "_notes": { "type": "object" }
      }
    },

    "voice": {
      "type": "object",
      "description": "Language signature of the audience: vocabulary they use and avoid, recurring expressions sourced from voc, tone register expected. Drives copy that reads native to them.",
      "properties": {
        "vocabulary_to_use": { "type": "array", "items": { "type": "string" } },
        "vocabulary_to_avoid": { "type": "array", "items": { "type": "string" } },
        "key_expressions": {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "text": { "type": "string" },
                  "origin": { "type": ["string", "null"], "enum": ["voc", "brand_declared", "inferred", ""] },
                  "platform": { "type": ["string", "null"] },
                  "frequency": { "type": ["integer", "number", "null"] },
                  "sample_size": { "type": ["integer", "number", "null"] },
                  "_notes": { "type": "object" }
                }
              }
            ]
          }
        },
        "tone_register": { "type": "string" },
        "_notes": { "type": "object" }
      }
    },

    "pain_points": {
      "type": "array",
      "description": "Problems this audience experiences that the product can address. Each pain has a depth chain (surface, consequence, deep), an associated emotion, a trigger context, and the awareness stage at which it becomes salient.",
      "items": {
        "type": "object",
        "properties": {
          "ref": { "type": "string" },
          "priority": { "type": ["integer", "null"] },
          "formulation": { "type": "string" },
          "chain": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "level": { "type": "string", "enum": ["surface", "consequence", "deep"] },
                "formulation": { "type": "string" }
              }
            }
          },
          "emotion": { "type": "string" },
          "trigger": { "type": "string" },
          "awareness_stage": { "$ref": "_shared/awareness-stage.json" },
          "_source_meta": {
            "type": "object",
            "properties": {
              "origin": { "type": "string", "enum": ["voc", "brand_declared", "inferred"] },
              "platform": { "type": "string" },
              "sample_size": { "type": ["integer", "null"] },
              "date_captured": { "type": "string" }
            }
          },
          "_notes": { "type": "object" }
        }
      }
    },

    "benefits": {
      "type": "array",
      "description": "Gains this audience expects from the product. Each benefit has a depth chain (functional, emotional, identity), an emotional lever, and the awareness stage at which it lands.",
      "items": {
        "type": "object",
        "properties": {
          "ref": { "type": "string" },
          "priority": { "type": ["integer", "null"] },
          "formulation": { "type": "string" },
          "chain": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "level": { "$ref": "_shared/benefit-chain-level.json" },
                "formulation": { "type": "string" }
              }
            }
          },
          "emotional_lever": { "type": "string" },
          "awareness_stage": { "$ref": "_shared/awareness-stage.json" },
          "_source_meta": {
            "type": "object",
            "properties": {
              "origin": { "type": "string", "enum": ["voc", "brand_declared", "inferred"] },
              "platform": { "type": "string" },
              "sample_size": { "type": ["integer", "null"] },
              "date_captured": { "type": "string" }
            }
          },
          "_notes": { "type": "object" }
        }
      }
    },

    "objections": {
      "type": "array",
      "description": "Reasons this audience hesitates to buy. Typed by category (price, skepticism, time, trust, urgency, efficacy, comparison), with frequency, severity, and the lifecycle stage at which it surfaces.",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": ["string", "null"], "enum": ["prix", "scepticisme", "temps", "confiance", "urgence", "efficacité", "comparaison", ""] },
          "formulation": { "type": "string" },
          "frequency": { "type": ["integer", "null"], "minimum": 1, "maximum": 10 },
          "severity": { "type": ["string", "null"], "enum": ["low", "medium", "high", ""] },
          "lifecycle_stage": { "type": ["string", "null"], "enum": ["awareness", "consideration", "decision", "post_purchase", ""] },
          "_notes": { "type": "object" }
        }
      }
    },

    "market_position": {
      "type": "object",
      "description": "Where the audience sits in the market awareness landscape (overall awareness level, optional sophistication override). Macro counterpart to the pain/benefit awareness_stage.",
      "properties": {
        "awareness_level": { "type": "string" },
        "sophistication_override": { "type": ["string", "null"] },
        "_notes": { "type": "string" }
      }
    },

    "research_meta": {
      "type": "object",
      "description": "Provenance of this audience profile: confidence level of the encoding, opportunity score for prioritization, and the sources used to build it.",
      "properties": {
        "confidence": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
        "opportunity_score": { "type": ["integer", "null"], "minimum": 1, "maximum": 10 },
        "sources_used": { "type": "array", "items": { "type": "string" } },
        "_notes": { "type": "object" }
      }
    }
  }
}
