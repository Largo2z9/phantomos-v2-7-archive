{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "objections.schema.json",
  "title": "Objection (audience-specific barrage achat)",
  "description": "Objection ressentie par audience(s) lors du parcours achat. v1.0 baseline ship v2.63 · refactor ontologie pure · extracted from profile.objections[] legacy v1.7. Cross-refs affected_audiences[]. Same pattern que friction + pain_points · top-level collection.",
  "_schema_version": "objections/1.0",
  "_changelog": {
    "1.0": "v2.63 baseline. Extracted from profile.objections[] legacy v1.7 (BREAKING). Top-level collection canonical. OBJ-NN id pattern."
  },
  "type": "object",
  "required": ["objection_id", "formulation", "type", "meta"],
  "properties": {
    "objection_id": { "type": "string", "pattern": "^OBJ-[0-9]{2,3}$" },
    "formulation": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["price", "scepticism", "fit", "urgency", "trust", "status", "risk"],
      "description": "7 types canon doctrine objections-mapping-doctrine.md"
    },
    "lifecycle_stage": {
      "type": "string",
      "enum": ["awareness", "consideration", "decision", "post_purchase"],
      "description": "4 lifecycle stages canon"
    },
    "frequency": { "enum": ["low", "medium", "high"], "description": "Fréquence mention verbatims" },
    "severity": { "enum": ["low", "medium", "high", "blocking"], "description": "Severity qualitative" },
    "severity_score": { "type": "integer", "minimum": 1, "maximum": 10, "description": "Severity score 1-10 canonical" },
    "response_counter": { "type": "string", "description": "Formulation neutralization testée canonical" },
    "verbatim_quotes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "source": { "type": "string" },
          "sample_size": { "type": "integer" }
        }
      }
    },
    "affected_audiences": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Audience slugs cross-ref"
    },
    "affected_products": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Product slugs cross-ref"
    },
    "derived_angle_refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^ANG-[0-9]{2,3}$" },
      "description": "Angles dérivés qui exploitent cette objection comme tension"
    },
    "meta": {
      "type": "object",
      "required": ["validation_status", "created", "_source"],
      "properties": {
        "validation_status": { "$ref": "_shared/validation-status.json" },
        "_source": { "enum": ["operator", "agent", "scrape", "mine_voc", "import"] },
        "created": { "type": "string", "format": "date-time" },
        "updated": { "type": "string", "format": "date-time" },
        "created_by_skill": { "type": "string" }
      }
    }
  }
}
